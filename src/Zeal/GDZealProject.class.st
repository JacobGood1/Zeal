Class {
	#name : 'GDZealProject',
	#superclass : 'Object',
	#instVars : [
		'name',
		'path',
		'modules',
		'registry'
	],
	#category : 'Zeal',
	#package : 'Zeal'
}

{ #category : 'transducer library' }
GDZealProject class >> transducerLibrarySource [
	"Returns the full text of the Zeal transducer runtime library as a single
	 GDScript file. Auto-deployed by ensureTransducerLibrary on first compile."
	^ 'class_name Z
extends RefCounted

# ============================================================================
# Zeal transducer runtime library — auto-generated by GDZealProject.
# Inspired by Clojure / Cognitect xforms / Jedi standard lib.
#
# A reducer is a Dictionary { "step": Callable(acc, item) -> acc-or-Reduced,
#                             "complete": Callable(acc) -> result }.
# A transducer is a Callable that takes a reducer and returns a new reducer.
# Reduced is the early-termination sentinel.
# ============================================================================

# ----- Reduced sentinel -----------------------------------------------------

class Reduced extends RefCounted:
	var value
	func _init(v): value = v

static func reduced(v) -> Reduced:
	return Reduced.new(v)

static func is_reduced(x) -> bool:
	return x is Reduced

# ----- Iterators (infinite sources) -----------------------------------------

class IterateIter extends RefCounted:
	# The GDScript iterator protocol calls _iter_get BEFORE the first _iter_next,
	# so `current` already needs to hold the seed when iteration begins.
	# _iter_next then advances unconditionally.
	var f: Callable
	var current
	func _init(fn: Callable, x):
		f = fn
		current = x
	func _iter_init(_a) -> bool: return true
	func _iter_next(_a) -> bool:
		current = f.call(current)
		return true
	func _iter_get(_a):
		return current

class RepeatIter extends RefCounted:
	var x
	func _init(v): x = v
	func _iter_init(_a) -> bool: return true
	func _iter_next(_a) -> bool: return true
	func _iter_get(_a): return x

class CycleIter extends RefCounted:
	var xs: Array
	var i: int = 0
	func _init(arr: Array): xs = arr
	func _iter_init(_a) -> bool:
		i = 0
		return not xs.is_empty()
	func _iter_next(_a) -> bool:
		i = (i + 1) % xs.size()
		return true
	func _iter_get(_a):
		return xs[i]

static func iterate_(f: Callable, x):
	return IterateIter.new(f, x)

static func repeat_(x):
	return RepeatIter.new(x)

static func cycle_(xs: Array):
	return CycleIter.new(xs)

# ----- Default reducers -----------------------------------------------------

static func append_rf() -> Dictionary:
	return {
		"step": func(acc, item):
			acc.append(item)
			return acc,
		"complete": func(acc): return acc
	}

# ----- Transducer factories -------------------------------------------------

static func mapping(f: Callable) -> Callable:
	return func(rf: Dictionary):
		return {
			"step": func(acc, item): return rf.step.call(acc, f.call(item)),
			"complete": rf.complete
		}

static func filtering(pred: Callable) -> Callable:
	return func(rf: Dictionary):
		return {
			"step": func(acc, item):
				return rf.step.call(acc, item) if pred.call(item) else acc,
			"complete": rf.complete
		}

static func taking(n: int) -> Callable:
	return func(rf: Dictionary):
		var seen := [0]
		return {
			"step": func(acc, item):
				if seen[0] >= n:
					return Reduced.new(acc)
				seen[0] += 1
				var result = rf.step.call(acc, item)
				if seen[0] >= n:
					return Reduced.new(result)
				return result,
			"complete": rf.complete
		}

static func dropping(n: int) -> Callable:
	return func(rf: Dictionary):
		var seen := [0]
		return {
			"step": func(acc, item):
				if seen[0] < n:
					seen[0] += 1
					return acc
				return rf.step.call(acc, item),
			"complete": rf.complete
		}

static func taking_while(pred: Callable) -> Callable:
	return func(rf: Dictionary):
		return {
			"step": func(acc, item):
				if pred.call(item):
					return rf.step.call(acc, item)
				return Reduced.new(acc),
			"complete": rf.complete
		}

static func dropping_while(pred: Callable) -> Callable:
	return func(rf: Dictionary):
		var dropping := [true]
		return {
			"step": func(acc, item):
				if dropping[0] and pred.call(item):
					return acc
				dropping[0] = false
				return rf.step.call(acc, item),
			"complete": rf.complete
		}

static func distinct_() -> Callable:
	return func(rf: Dictionary):
		var seen := {}
		return {
			"step": func(acc, item):
				if seen.has(item):
					return acc
				seen[item] = true
				return rf.step.call(acc, item),
			"complete": rf.complete
		}

static func dedupe_() -> Callable:
	return func(rf: Dictionary):
		var prev := [null, false]  # [value, has_prev]
		return {
			"step": func(acc, item):
				if prev[1] and prev[0] == item:
					return acc
				prev[0] = item
				prev[1] = true
				return rf.step.call(acc, item),
			"complete": rf.complete
		}

static func keeping(f: Callable) -> Callable:
	return func(rf: Dictionary):
		return {
			"step": func(acc, item):
				var v = f.call(item)
				if v == null:
					return acc
				return rf.step.call(acc, v),
			"complete": rf.complete
		}

static func flattening() -> Callable:
	return func(rf: Dictionary):
		return {
			"step": func(acc, item):
				if item is Array:
					var a = acc
					for sub in item:
						a = rf.step.call(a, sub)
						if a is Reduced:
							return a
					return a
				return rf.step.call(acc, item),
			"complete": rf.complete
		}

static func indexing() -> Callable:
	return func(rf: Dictionary):
		var i := [0]
		return {
			"step": func(acc, item):
				var pair = [i[0], item]
				i[0] += 1
				return rf.step.call(acc, pair),
			"complete": rf.complete
		}

static func chunking(n: int, step: int = -1) -> Callable:
	var actual_step = n if step < 0 else step
	return func(rf: Dictionary):
		# buf is mutated in-place — closures capture by reference for arrays.
		# Reassigning buf inside a closure (`buf = buf.slice(...)`) does NOT
		# propagate to subsequent calls, so we always mutate via clear/append.
		var buf := []
		var skip := [0]
		return {
			"step": func(acc, item):
				if skip[0] > 0:
					skip[0] -= 1
					return acc
				buf.append(item)
				if buf.size() >= n:
					var chunk = buf.duplicate()
					var result = rf.step.call(acc, chunk)
					if actual_step >= n:
						buf.clear()
						skip[0] = actual_step - n
					else:
						# Drop the first `actual_step` elements in place.
						var keep = buf.slice(actual_step)
						buf.clear()
						buf.append_array(keep)
					return result
				return acc,
			"complete": func(acc):
				# Flush trailing partials. For sliding windows (step < n) we keep
				# shifting by `actual_step` and re-emitting until buf is empty —
				# matches Clojure partition-all semantics.
				var current = acc
				while not buf.is_empty():
					var chunk = buf.duplicate()
					current = rf.step.call(current, chunk)
					if current is Reduced:
						return rf.complete.call(current.value)
					if actual_step >= buf.size():
						buf.clear()
					else:
						var keep = buf.slice(actual_step)
						buf.clear()
						buf.append_array(keep)
				return rf.complete.call(current)
		}

static func chunking_by(f: Callable) -> Callable:
	return func(rf: Dictionary):
		var buf := []
		var prev_key := [null, false]   # [key, has_key]
		return {
			"step": func(acc, item):
				var key = f.call(item)
				if not prev_key[1]:
					prev_key[0] = key
					prev_key[1] = true
					buf.append(item)
					return acc
				if key == prev_key[0]:
					buf.append(item)
					return acc
				var chunk = buf.duplicate()
				buf.clear()
				buf.append(item)
				prev_key[0] = key
				return rf.step.call(acc, chunk),
			"complete": func(acc):
				if buf.is_empty():
					return rf.complete.call(acc)
				var chunk = buf.duplicate()
				buf.clear()
				var result = rf.step.call(acc, chunk)
				if result is Reduced:
					return rf.complete.call(result.value)
				return rf.complete.call(result)
		}

static func mapcatting(f: Callable) -> Callable:
	return func(rf: Dictionary):
		return {
			"step": func(acc, item):
				var inner = f.call(item)
				var a = acc
				for sub in inner:
					a = rf.step.call(a, sub)
					if a is Reduced:
						return a
				return a,
			"complete": rf.complete
		}

static func mapcatting_indexed(f: Callable) -> Callable:
	return func(rf: Dictionary):
		var i := [0]
		return {
			"step": func(acc, item):
				var inner = f.call(i[0], item)
				i[0] += 1
				var a = acc
				for sub in inner:
					a = rf.step.call(a, sub)
					if a is Reduced:
						return a
				return a,
			"complete": rf.complete
		}

static func keeping_indexed(f: Callable) -> Callable:
	return func(rf: Dictionary):
		var i := [0]
		return {
			"step": func(acc, item):
				var v = f.call(i[0], item)
				i[0] += 1
				if v == null:
					return acc
				return rf.step.call(acc, v),
			"complete": rf.complete
		}

static func interposing(sep) -> Callable:
	return func(rf: Dictionary):
		var first := [true]
		return {
			"step": func(acc, item):
				if first[0]:
					first[0] = false
					return rf.step.call(acc, item)
				var a = rf.step.call(acc, sep)
				if a is Reduced:
					return a
				return rf.step.call(a, item),
			"complete": rf.complete
		}

static func dropping_last(n: int = 1) -> Callable:
	return func(rf: Dictionary):
		var buf := []
		return {
			"step": func(acc, item):
				buf.append(item)
				if buf.size() > n:
					var head = buf.pop_front()
					return rf.step.call(acc, head)
				return acc,
			"complete": rf.complete  # any leftover in buf is dropped
		}

# ----- Drivers --------------------------------------------------------------

static func transduce(xform: Callable, rf: Dictionary, init, source) -> Variant:
	var stepped = xform.call(rf)
	var acc = init
	for item in source:
		acc = stepped.step.call(acc, item)
		if acc is Reduced:
			acc = acc.value
			break
	return stepped.complete.call(acc)

static func into(dest: Array, xform: Callable, source) -> Array:
	return transduce(xform, append_rf(), dest.duplicate(), source)

# ----- Eager reducers -------------------------------------------------------

static func sum(xs) -> Variant:
	var acc = 0
	for x in xs:
		acc += x
	return acc

static func product(xs) -> Variant:
	var acc = 1
	for x in xs:
		acc *= x
	return acc

static func tally(xs) -> Dictionary:
	var d := {}
	for x in xs:
		d[x] = d.get(x, 0) + 1
	return d

static func avg(xs) -> float:
	var s = 0.0
	var n = 0
	for x in xs:
		s += x
		n += 1
	return s / n if n > 0 else 0.0

static func max_of(xs) -> Variant:
	var m = null
	for x in xs:
		if m == null or x > m:
			m = x
	return m

static func min_of(xs) -> Variant:
	var m = null
	for x in xs:
		if m == null or x < m:
			m = x
	return m

static func any(pred: Callable, xs) -> bool:
	for x in xs:
		if pred.call(x):
			return true
	return false

static func every(pred: Callable, xs) -> bool:
	for x in xs:
		if not pred.call(x):
			return false
	return true

static func into_array(xs) -> Array:
	var out := []
	for x in xs:
		out.append(x)
	return out

static func into_map(xs) -> Dictionary:
	var d := {}
	for pair in xs:
		d[pair[0]] = pair[1]
	return d

static func into_string(xs) -> String:
	var s := ""
	for x in xs:
		s += str(x)
	return s

static func reduce(f: Callable, init, xs) -> Variant:
	var acc = init
	var first = init == null
	for x in xs:
		if first:
			acc = x
			first = false
		else:
			acc = f.call(acc, x)
	return acc

# ----- Combinators ----------------------------------------------------------

static func comp(xforms: Array) -> Callable:
	return func(rf: Dictionary):
		var result = rf
		for i in range(xforms.size() - 1, -1, -1):
			result = xforms[i].call(result)
		return result

static func juxt(fs: Array) -> Callable:
	return func(x):
		var out := []
		for f in fs:
			out.append(f.call(x))
		return out

# ----- Eager-only -----------------------------------------------------------

static func interleave(arrays: Array) -> Array:
	if arrays.is_empty():
		return []
	var min_len = arrays[0].size()
	for a in arrays:
		if a.size() < min_len:
			min_len = a.size()
	var out := []
	for i in range(min_len):
		for a in arrays:
			out.append(a[i])
	return out
'
]

{ #category : 'definitions' }
GDZealProject >> addDefinition: aNode fromSource: sourceString [
	"Add a definition to the right module based on its type. If a definition with
	 the same name exists in a DIFFERENT module (e.g. defsystem → defcosystem rename),
	 delete the old one (and its files) before adding the new one. This prevents
	 name conflicts like HealthDrainSystem existing in both systems/ and components/."
	| folder mod existing |
	folder := self folderFor: aNode.
	mod := modules at: folder.
	aNode rawSource: sourceString.
	aNode parent: mod.
	"Check ALL modules for a same-named definition in a different folder — remove it"
	modules keysAndValuesDo: [ :otherFolder :otherMod |
		otherFolder = folder ifFalse: [
			otherMod definitions copy do: [ :d |
				((d isKindOf: ZealDefinition) and: [ d name = aNode name ]) ifTrue: [
					"Delete the old definition's files and remove from its module"
					self deleteDefinition: d ] ] ] ].
	"Replace existing def with same name in the TARGET module"
	existing := mod definitions detect: [ :d |
		(d isKindOf: ZealDefinition) and: [ d name = aNode name ] ] ifNone: [ nil ].
	existing
		ifNotNil: [ mod definitions at: (mod definitions indexOf: existing) put: aNode ]
		ifNil: [ mod definitions add: aNode ].
	(aNode annotations includesAny: #('gecs_component')) ifTrue: [
		registry register: aNode name ]
]

{ #category : 'accessing' }
GDZealProject >> allDefinitions [
	"All definitions across all modules"
	^ modules values flatCollect: [ :mod | mod definitions ]
]

{ #category : 'persistence' }
GDZealProject >> compileAll [
	"Compile all definitions to GDScript"
	| count errors |
	count := 0. errors := 0.
	self allDefinitions do: [ :node |
		[ self compileDefinition: node.
		  count := count + 1 ]
		on: Error do: [ :e | errors := errors + 1 ] ].
	^ count -> errors
]

{ #category : 'compiling' }
GDZealProject >> compileDefinition: aNode [
	"Compile a single definition to GDScript and write to Godot project."
	| gdScript gdPath snakeName folder source absRef |
	self ensureTransducerLibrary.
	folder := self folderFor: aNode.
	snakeName := aNode name copyReplaceAll: '-' with: '_'.
	folder = 'components' ifTrue: [ gdPath := 'components/c_' , snakeName , '.gd' ].
	folder = 'entities' ifTrue: [ gdPath := 'entities/' , snakeName , '.gd' ].
	folder = 'systems' ifTrue: [ gdPath := 'systems/' , snakeName , '.gd' ].
	folder = 'observers' ifTrue: [ gdPath := 'observers/' , snakeName , '.gd' ].
	folder = 'scenes' ifTrue: [ gdPath := 'scenes/' , snakeName , '.gd' ].
	gdPath ifNil: [ gdPath := 'scripts/' , snakeName , '.gd' ].
	source := aNode rawSource.
	gdScript := GDZealCodeGenerator compile: source withRegistry: registry.
	"scripts/ need extends RefCounted for preload().new()"
	folder = 'scripts' ifTrue: [
		gdScript := 'extends RefCounted' , String lf , String lf , gdScript ].
	absRef := (path , '/' , gdPath) asFileReference.
	absRef parent ensureCreateDirectory.
	absRef
		ensureDelete;
		writeStreamDo: [ :s | s nextPutAll: gdScript ].
	"defcosystem: generate sibling system"
	(GDZealCompiler isDefcosystem: source) ifTrue: [
		| systemSrc systemPath bindings sysRef sysSnake |
		bindings := GDZealCompiler defcosystemBindings: source.
		systemSrc := GDZealCompiler compileFsmSystemFor: aNode name withBindings: bindings.
		sysSnake := snakeName.
		(sysSnake endsWith: '_system') ifTrue: [ sysSnake := sysSnake allButLast: 7 ].
		systemPath := 'systems/' , sysSnake , '_system.gd'.
		sysRef := (path , '/' , systemPath) asFileReference.
		sysRef parent ensureCreateDirectory.
		sysRef ensureDelete; writeStreamDo: [ :s | s nextPutAll: systemSrc ] ].
	"defscene: generate the .tscn scene file with World node + all systems"
	(source includesSubstring: '(defscene ') ifTrue: [
		self generateSceneTscn: snakeName gdPath: gdPath ].
	^ gdPath
]

{ #category : 'definitions' }
GDZealProject >> deleteDefinition: aNode [
	"Remove a definition from the project: deletes the .zeal source file, the
	 generated .gd file, and the sibling _system.gd for defcosystems. Strips
	 -system suffix from names to match the compile path logic."
	| folder snakeName gdPath sysPath src zealPath |
	(aNode isKindOf: ZealDefinition) ifFalse: [ ^ nil ].
	folder := self folderFor: aNode.
	snakeName := aNode name copyReplaceAll: '-' with: '_'.
	zealPath := path , '/gdzeal/' , folder , '/' , aNode name , '.zeal'.
	zealPath asFileReference ensureDelete.
	folder = 'components'
		ifTrue: [ gdPath := 'components/c_' , snakeName , '.gd' ]
		ifFalse: [ gdPath := folder , '/' , snakeName , '.gd' ].
	(path , '/' , gdPath) asFileReference ensureDelete.
	src := aNode rawSource.
	(src notNil and: [ GDZealCompiler isDefcosystem: src ]) ifTrue: [
		| sysSnake |
		sysSnake := snakeName.
		(sysSnake endsWith: '_system') ifTrue: [ sysSnake := sysSnake allButLast: 7 ].
		sysPath := 'systems/' , sysSnake , '_system.gd'.
		(path , '/' , sysPath) asFileReference ensureDelete ].
	self removeDefinition: aNode.
	^ gdPath
]

{ #category : 'transducer library' }
GDZealProject >> ensureTransducerLibrary [
	"Write addons/zeal/zeal_transducers.gd to disk if it doesn't exist OR if its
	 contents differ from the embedded source. Called from compileDefinition: so
	 every compile guarantees the library is present and up to date."
	| libRef libDir embedded current |
	libRef := (path , '/addons/zeal/zeal_transducers.gd') asFileReference.
	libDir := libRef parent.
	libDir ensureCreateDirectory.
	embedded := GDZealProject transducerLibrarySource.
	libRef exists ifTrue: [
		current := [ libRef contents ] on: Error do: [ :e | nil ].
		current = embedded ifTrue: [ ^ self ] ].
	libRef
		ensureDelete;
		writeStreamDo: [ :s | s nextPutAll: embedded ]
]

{ #category : 'accessing' }
GDZealProject >> externalModules [
	"GDZeal has no external modules"
	^ #()
]

{ #category : 'private' }
GDZealProject >> extractDefName: source [
	| forms |
	forms := #('defcomp ' 'defentity ' 'defsystem ' 'defobserver ' 'defn ').
	forms do: [ :form |
		| pos |
		pos := source findString: '(' , form.
		pos > 0 ifTrue: [
			| start end |
			start := pos + form size + 1.
			end := start.
			[ end <= source size and: [ (source at: end) isLetter or: [ (source at: end) isDigit or: [ '-_' includes: (source at: end) ] ] ] ] whileTrue: [ end := end + 1 ].
			end > start ifTrue: [ ^ source copyFrom: start to: end - 1 ] ] ].
	^ nil
]

{ #category : 'accessing' }
GDZealProject >> findDefinition: aName [
	"Find a definition by name across all modules"
	^ self allDefinitions
		detect: [ :d | d name = aName ]
		ifNone: [ nil ]
]

{ #category : 'definitions' }
GDZealProject >> folderFor: aNode [
	"Determine folder for a definition based on superclass/annotations"
	(aNode isKindOf: ZealClass) ifFalse: [ ^ 'scripts' ].
	aNode superclass = 'Component' ifTrue: [ ^ 'components' ].
	aNode superclass = 'Entity' ifTrue: [ ^ 'entities' ].
	aNode superclass = 'System' ifTrue: [ ^ 'systems' ].
	aNode superclass = 'Observer' ifTrue: [ ^ 'observers' ].
	aNode superclass = 'Scene' ifTrue: [ ^ 'scenes' ].
	^ 'scripts'
]

{ #category : 'compiling' }
GDZealProject >> generateSceneTscn: snakeName gdPath: gdPath [
	"Generate a .tscn scene file for a defscene. Includes a World node with all
	 known systems auto-added as children."
	| tscnPath systemFiles resourceIdx |
	tscnPath := path , '/scenes/' , snakeName , '.tscn'.
	"Collect all system .gd files"
	systemFiles := OrderedCollection new.
	(path , '/systems') asFileReference exists ifTrue: [
		(path , '/systems') asFileReference children do: [ :f |
			f extension = 'gd' ifTrue: [ systemFiles add: f ] ] ].
	resourceIdx := 1.
	tscnPath asFileReference ensureDelete.
	tscnPath asFileReference writeStreamDo: [ :s |
		| loadSteps |
		loadSteps := 2 + systemFiles size.  "scene script + world script + systems"
		s nextPutAll: '[gd_scene load_steps='; nextPutAll: loadSteps printString; nextPutAll: ' format=3]'; lf; lf.
		"Scene script"
		s nextPutAll: '[ext_resource type="Script" path="res://'; nextPutAll: gdPath; nextPutAll: '" id="1_scene"]'; lf.
		"World script"
		s nextPutAll: '[ext_resource type="Script" path="res://addons/gecs/ecs/world.gd" id="2_world"]'; lf.
		"System scripts"
		systemFiles withIndexDo: [ :f :idx |
			s nextPutAll: '[ext_resource type="Script" path="res://systems/'; nextPutAll: f basename; nextPutAll: '" id="'; nextPutAll: (idx + 2) printString; nextPutAll: '_sys"]'; lf ].
		s lf.
		"Root node"
		s nextPutAll: '[node name="'; nextPutAll: (snakeName copyReplaceAll: '_' with: ' ') capitalized; nextPutAll: '" type="Node2D"]'; lf.
		s nextPutAll: 'script = ExtResource("1_scene")'; lf; lf.
		"World node"
		s nextPutAll: '[node name="World" type="Node" parent="."]'; lf.
		s nextPutAll: 'script = ExtResource("2_world")'; lf.
		s nextPutAll: 'system_nodes_root = NodePath(".")'; lf.
		s nextPutAll: 'entity_nodes_root = NodePath(".")'; lf; lf.
		"System nodes under World"
		systemFiles withIndexDo: [ :f :idx |
			| sysName |
			sysName := f basenameWithoutExtension.
			s nextPutAll: '[node name="'; nextPutAll: sysName; nextPutAll: '" type="Node" parent="World"]'; lf.
			s nextPutAll: 'script = ExtResource("'; nextPutAll: (idx + 2) printString; nextPutAll: '_sys")'; lf; lf ] ]
]

{ #category : 'initialization' }
GDZealProject >> initialize [
	modules := OrderedDictionary new.
	registry := GDZealComponentRegistry new.
	#('components' 'entities' 'systems' 'observers' 'scenes' 'scripts') do: [ :folder |
		| mod |
		mod := ZealModule new name: folder; kind: #folder; definitions: OrderedCollection new.
		modules at: folder put: mod ]
]

{ #category : 'loading' }
GDZealProject >> loadFromDirectory [
	"Scan gdzeal/ directory and load all .zeal files as ZealNode definitions"
	| zealDir |
	zealDir := (path , '/gdzeal') asFileReference.
	zealDir exists ifFalse: [ ^ self ].
	"First pass: register components"
	modules valuesDo: [ :mod |
		| dir |
		dir := zealDir / mod name.
		dir exists ifTrue: [
			(dir children select: [ :f | f extension = 'zeal' ]) do: [ :f |
				| src |
				src := f contents.
				(src includesSubstring: '(defcomp ') ifTrue: [
					| defName |
					defName := self extractDefName: src.
					defName ifNotNil: [ registry register: defName ] ] ] ] ].
	"Second pass: compile all"
	modules valuesDo: [ :mod |
		| dir |
		dir := zealDir / mod name.
		mod definitions: OrderedCollection new.
		dir exists ifTrue: [
			(dir children select: [ :f | f extension = 'zeal' ]) do: [ :f |
				| src node |
				src := f contents.
				[ node := GDZealCompiler compile: src.
				  node rawSource: src.
				  node parent: mod.
				  mod definitions add: node ]
				on: Error do: [ :e | "skip broken files" ] ] ] ]
]

{ #category : 'loading' }
GDZealProject >> loadFromImage [
	"Reload project from generated Smalltalk classes"
	| genClasses |
	genClasses := Smalltalk globals allClasses select: [ :c |
		c name beginsWith: 'GDZ_' ].
	genClasses do: [ :cls |
		| source node |
		[ source := cls zealSource.
		  node := GDZealCompiler compile: source.
		  node rawSource: source.
		  node generatedClass: cls.
		  self addDefinition: node fromSource: source ]
		on: Error do: [ :e | "skip broken" ] ]
]

{ #category : 'accessing' }
GDZealProject >> modules [
	^ modules
]

{ #category : 'accessing' }
GDZealProject >> name [
	^ name ifNil: [ 'GDZeal' ]
]

{ #category : 'accessing' }
GDZealProject >> name: aString [
	name := aString
]

{ #category : 'accessing' }
GDZealProject >> path [
	^ path
]

{ #category : 'accessing' }
GDZealProject >> path: aString [
	path := aString
]

{ #category : 'persistence' }
GDZealProject >> persistToImage [
	"Persist all definitions as generated Smalltalk classes for image-based storage.
	 Generated classes go in GDZeal-Generated package, methods classified under 'metadata'.
	 Only proper ZealDefinitions (not stray top-level expressions) get persisted."
	(self allDefinitions select: [ :n | n isKindOf: ZealDefinition ]) do: [ :node |
		| className cls |
		className := ('GDZ_' , (node name copyReplaceAll: '-' with: '_')) asSymbol.
		cls := Smalltalk globals at: className ifAbsent: [
			Object subclass: className
				instanceVariableNames: ''
				classVariableNames: ''
				package: 'GDZeal-Generated' ].
		cls class compile: 'zealSource ^ ' , node rawSource printString classified: 'metadata'.
		cls class compile: 'zealNodeType ^ ' , node class name printString classified: 'metadata'.
		cls class compile: 'zealName ^ ' , node name printString classified: 'metadata'.
		(node isKindOf: ZealClass)
			ifTrue: [ cls class compile: 'zealSuperclass ^ ' , node superclass printString classified: 'metadata' ]
			ifFalse: [ cls class compile: 'zealSuperclass ^ nil' classified: 'metadata' ].
		node generatedClass: cls ]
]

{ #category : 'accessing' }
GDZealProject >> registry [
	^ registry
]

{ #category : 'actions' }
GDZealProject >> removeDefinition: aNode [
	"Remove a definition from its module"
	modules valuesDo: [ :mod |
		mod definitions remove: aNode ifAbsent: [] ]
]

{ #category : 'persistence' }
GDZealProject >> saveDefinition: aNode [
	"Save .zeal source file for a definition"
	| folder fileName filePath |
	folder := self folderFor: aNode.
	fileName := aNode name , '.zeal'.
	filePath := path , '/gdzeal/' , folder , '/' , fileName.
	filePath asFileReference parent ensureCreateDirectory.
	filePath asFileReference
		ensureDelete;
		writeStreamDo: [ :s | s nextPutAll: aNode rawSource ]
]
